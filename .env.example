# Environment Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to Git!

# ==================== Application Settings ====================
APP_NAME=banking_support_agent
APP_ENV=development  # development, production
DEBUG=True  # True for development, False for production

# ==================== Model Settings ====================
MODEL_NAME=distilbert-base-uncased
MODEL_PATH=./models/intent-distilbert
NUM_LABELS=3
BATCH_SIZE=16
EPOCHS=3
LEARNING_RATE=2e-5
MAX_LENGTH=128

# ==================== Data Paths ====================
DATA_DIR=./data
TRAIN_CSV=./data/banking_support_dataset_train_model.csv
TICKET_CSV=./data/support_tickets.csv

# ==================== Database Settings (Future) ====================
# DATABASE_URL=postgresql://user:password@localhost:5432/banking_support
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10

# ==================== Gradio Settings ====================
GRADIO_SHARE=False
GRADIO_DEBUG=True
GRADIO_SERVER_NAME=127.0.0.1
GRADIO_SERVER_PORT=7860

# ==================== API Settings (Future) ====================
# API_KEY=your-secret-api-key-here
# API_RATE_LIMIT=100  # requests per minute

# ==================== Logging ====================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=./logs/app.log

# ==================== Security ====================
# SECRET_KEY=your-secret-key-here-generate-with-python-secrets-token-hex-32
# ENCRYPTION_KEY=your-encryption-key-here
